# OpenAI-compatible speech recognition endpoint (required for cloud ASR)
ASR_API_KEY=
ASR_BASE_URL=
ASR_MODEL=mimo-v2.5-asr
ASR_API_MODE=chat

# Optional transcript correction endpoint
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Optional tuning
ASR_SEGMENT_SECONDS=300
ASR_WORKERS=4
WECHAT_MIN_VIDEO_BYTES=1048576
# WECHAT_OUTPUT_DIR=D:\Downloads\WeChat-video-download

# Local Whisper alternative
USE_WHISPER=false
WHISPER_MODEL=large
